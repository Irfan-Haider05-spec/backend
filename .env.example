# ============================================================
# .env.example — Copy this to .env and fill in real values
# NEVER commit your real .env to Git
# ============================================================

# ── Server ──────────────────────────────────────────────────
NODE_ENV=production
PORT=5004

# ── Database ────────────────────────────────────────────────
# For production: use your managed Atlas/VPS MongoDB URI
MONGODB_URI=mongodb://admin:changeme@mongo:27017/mlitech_db?authSource=admin

# Local Docker MongoDB credentials (used only in docker-compose)
MONGO_ROOT_USER=admin
MONGO_ROOT_PASS=changeme

# ── JWT ─────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE_IN=1d
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_REFRESH_EXPIRE_IN=30d

# ── Bcrypt ──────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12

# ── Email (Nodemailer) ──────────────────────────────────────
EMAIL_FROM=noreply@yourdomain.com
EMAIL_USER=your_smtp_user
EMAIL_PASS=your_smtp_password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587

# ── Stripe ──────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# ── Firebase ────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your_project.iam.gserviceaccount.com

# ── Twilio ──────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ── Google OAuth ────────────────────────────────────────────
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxx

# ── Client URLs (CORS) ──────────────────────────────────────
CLIENT_URL=https://yourfrontend.com
ADMIN_URL=https://admin.yourfrontend.com